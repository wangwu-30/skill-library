# Control-plane repository for the local skill system.
# Track local governance and house skills; ignore mirrored upstream repos and generated outputs.

/*

!/.gitignore
!/Agent.md
!/AGENTS.md
!/CLAUDE.md
!/LICENSE
!/pyproject.toml
!/README.md
!/.cursor/
!/.cursor/rules/
!/.cursor/rules/**
!/.githooks/
!/.githooks/**
!/.agents/
!/.agents/workflows/
!/.agents/workflows/**
!/examples/
!/examples/**
!/house-skills/
!/house-skills/**
!/docs/
!/docs/**
!/eval/
!/eval/**
!/catalog/

/catalog/*
!/catalog/tracked_repos.json
!/catalog/blacklisted_repos.json

/CATALOG.md
/memory.md
/catalog/skill_catalog.json
/catalog/daily_skill_watch_last.json

__pycache__/
*.pyc
